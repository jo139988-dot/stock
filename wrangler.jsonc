{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "stock",
  "main": "worker/index.ts",
  "compatibility_date": "2026-05-15",
  "compatibility_flags": [
    "global_fetch_strictly_public"
  ],
  "assets": {
    "directory": "out",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "triggers": {
    "crons": [
      "*/5 * * * *"
    ]
  }
}
